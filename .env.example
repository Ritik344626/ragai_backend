APP_NAME=RAG Trends API
APP_ENV=development
API_V1_PREFIX=/api/v1
SOURCE_PREVIEW_MAX_ITEMS=20
EXTERNAL_REQUEST_TIMEOUT_SECONDS=15
GOOGLE_TRENDS_PN=india
INGESTION_DEFAULT_LIMIT=15

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rag_trends_db

# LLM - Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# RAG relevance controls
RAG_MIN_SIMILARITY_FOR_CONTEXT=0.22
RAG_MIN_LEXICAL_OVERLAP_FOR_CONTEXT=0.10
RAG_MIN_HYBRID_SCORE_FOR_CONTEXT=0.24
RAG_ENABLE_FUZZY_LEXICAL_MATCH=true
RAG_FUZZY_TOKEN_MATCH_RATIO=0.84
RAG_STRONG_SIMILARITY_OVERRIDE=0.38
RAG_ENABLE_RELAXED_FALLBACK=true
RAG_RELAXED_MIN_SIMILARITY_FOR_CONTEXT=0.14
RAG_RELAXED_MIN_LEXICAL_OVERLAP_FOR_CONTEXT=0.05
RAG_RELAXED_MIN_HYBRID_SCORE_FOR_CONTEXT=0.16
RAG_MIN_RELEVANT_CHUNKS=1
RAG_MAX_SOURCES_FOR_SUMMARY=5
RAG_MAX_CHUNKS_PER_SOURCE=2


# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=UTC
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=600
CELERY_TASK_TIME_LIMIT_SECONDS=900
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=20
CELERY_BEAT_ENABLED=true
CELERY_BEAT_CRON_MINUTE=*/30
CELERY_BEAT_CRON_HOUR=*
CELERY_BEAT_CRON_DAY_OF_WEEK=*
CELERY_BEAT_CRON_DAY_OF_MONTH=*
CELERY_BEAT_CRON_MONTH_OF_YEAR=*
CELERY_BEAT_AUTO_LIMIT=15
CELERY_AUTO_SOURCES_CSV=google_news_ai,google_news_global,hackernews_topstories,google_trends_daily

# Embedding runtime safety (recommended on macOS + Celery workers)
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
